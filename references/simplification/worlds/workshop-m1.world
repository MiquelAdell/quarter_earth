    {
      "id": "7dc427d5-07b4-4df2-be47-fe1156b3c25c",
      "name": "Artificial Moons",
      "kind": "Initiative",
      "group": "Geoengineering",
      "ongoing": false,
      "gradual": false,
      "locked": true,
      "cost": 0,
      "base_cost": {
