              {
                "id": 1,
                "next": null,
                "speaker": "Gossy",
                "text": ""
              },
              {
                "id": 2,
                "next": null,
                "speaker": "The Ecologist",
                "text": "The success of this initiative will depend on our ability to offer equitable alternative livelihoods for people who work in the wildlife trade."
              },
